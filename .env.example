# Copie este arquivo para .env e preencha. O .env NAO vai para o controle de versao.

# --- Nomus (obrigatorio) -------------------------------------------------------------
# Chave em Base64: Nomus -> Configuracao Geral -> "Chave de acesso para integracao com o
# ERP via REST". Fica so aqui, no servidor; o browser nunca a recebe.
NOMUS_API_KEY=

# Alternativa a NOMUS_API_KEY, caso voce tenha usuario e senha em texto (o servidor faz o
# Base64). Use uma OU outra, nao as duas.
# NOMUS_USUARIO_SENHA=usuario:senha

NOMUS_BASE_URL=https://constelha.nomus.com.br/constelha/rest

# --- Terminal (obrigatorio) ----------------------------------------------------------
# Matricula do funcionario deste terminal. Cada terminal aponta para um operador so.
NOMUS_MATRICULA=

# --- Terminal (opcional) -------------------------------------------------------------
# Atividade padrao POR NOME, ex.: Producao
# O terminal aponta todos os setores, e cada recurso tem sua propria "Producao" com id
# diferente — por isso o padrao casa por nome, e nao por id. Se o nome nao existir no
# recurso da vez, a tela pergunta. Defina para eliminar um toque a cada Iniciar.
# NOMUS_ATIVIDADE_PADRAO=Producao

# O RECURSO nao se configura aqui: ele sai do centro de trabalho da etapa lida, sempre
# automatico. Centro com mais de uma maquina cai na primeira ativa e o log avisa.

# Motivos de parada (nomes separados por virgula). Sao atividades do proprio Nomus, e a API
# nao tem flag que diga "isto e uma parada". Vazio = toda atividade do recurso que nao pede
# quantidade nem percentual (quem para nao produz peca), o que ja exclui Producao e
# Retrabalho. Preencha se o cadastro nao seguir essa logica.
# NOMUS_ATIVIDADES_PARADA=Parada tecnica,Parada para refeicao,Banheiro,Quebra de maquina

# Usado so se o funcionario nao tiver limiteApontamentosSimultaneos no Nomus. 0 = sem limite.
LIMITE_APONTAMENTOS_FALLBACK=0

PORT=3000

# --- Numero do pedido nos cards ------------------------------------------------------
# /operacoesRoteiroOrdem nao traz o pedido. Confirmado contra o Nomus real (Grupo Ferro) em
# 2026-07-15: o vinculo e GET /ordens[].itensPedido[0].idPedido == GET /pedidos/{id} (busca
# por UM id, nunca a listagem inteira — /pedidos tem milhares de registros e e fortemente
# limitado por rate limit). O codigo fica em pedidos[].codigoPedido (ex.: "PD 01294"). Os
# padroes abaixo ja refletem isso; so mude se sua instancia expuser nomes diferentes (rode
# node ferramentas/diagnostico.js pra conferir).
# NOMUS_ENDPOINT_ORDENS=/ordens
# NOMUS_ENDPOINT_PEDIDOS=/pedidos
# NOMUS_CAMPO_PEDIDO=codigoPedido

# Cache de pedidos em disco — pedido praticamente nao muda depois de criado, e sem cache
# persistido todo restart do servidor rebuscaria cada um de novo e tomaria 429.
# PEDIDO_CACHE_TTL_MS=86400000        # 24h

# Uma empresa com muitas ordens abertas pode ter centenas de pedidos distintos ainda nao
# cacheados no 1o boot. Buscar todos de uma vez sem pausa foi o que causou uma avalanche de
# 429 (ver comentario no topo de server/pedidos.js) — o teto abaixo busca so um pouco de
# cada vez por chamada; o resto aparece nos cards nos ciclos seguintes, conforme o cache
# esquenta. Aumente PEDIDO_MAX_NOVOS_POR_CICLO so se souber que sua empresa tem poucas
# ordens/pedidos distintos.
# PEDIDO_PAUSA_MS=250
# PEDIDO_MAX_NOVOS_POR_CICLO=20
# PEDIDO_CACHE_FILE=./dados/cache-pedidos.json

# --- Ajustes finos -------------------------------------------------------------------
# Onde ficam os apontamentos em andamento (a UNICA copia deles ate o Finalizar).
# Padrao: ./dados/andamento.json. Inclua este caminho na rotina de backup.
# ARQUIVO_ANDAMENTO=./dados/andamento.json

# TTL do cache de operacoes/apontamentos/ordens (paginados por inteiro — dezenas de
# chamadas). 3 minutos e o valor validado por um projeto irmao rodando contra este mesmo
# Nomus ha dias; nao baixe sem necessidade.
# CACHE_TTL_MS=180000

# Esse cache persiste em disco e sobrevive a um restart do processo: quando o valor esta
# vencido mas ainda existe, o app devolve o valor antigo NA HORA e atualiza em segundo
# plano (stale-while-revalidate) — so espera de verdade quando nao ha NADA em cache (1o
# boot). Sem isso, cada restart forcava uma varredura completa cara e, sob rate limit,
# deixava o kanban sem carregar por minutos.
# ARQUIVO_CACHE_NOMUS=./dados/cache-nomus.json
# NOMUS_TIMEOUT_MS=20000
# MAX_ESPERA_THROTTLE_MS=30000  # teto de espera ao levar 429 antes de devolver erro
# MAX_TENTATIVAS_THROTTLE=3
